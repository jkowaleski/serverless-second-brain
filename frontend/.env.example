# API Gateway invoke URL (from: cd infra/environments/dev && terraform output api_gateway_invoke_url)
VITE_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/dev

# Cognito (from: terraform output cognito_*)
VITE_COGNITO_DOMAIN=https://YOUR_PROJECT-dev.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your_spa_client_id
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
