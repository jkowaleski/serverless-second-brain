# Required — customize for your deployment
project_name = "ssb"
environment  = "dev"
digest_email = "you@example.com"

# Frontend URLs — update after first deploy with your CloudFront domain
cors_allow_origin     = "*"
cognito_callback_urls = ["http://localhost:5173/callback"]
cognito_logout_urls   = ["http://localhost:5173"]

